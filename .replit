modules = ["python-3.12", "nodejs-20"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Start"

[[workflows.workflow]]
name = "Start"
author = "user"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 8080

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client && npm run dev -- --port 3000 --host"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[agent]
expertMode = true
